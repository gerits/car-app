import "../assets/SpaceGrotesk-VariableFont_wght.ttf";
import "../assets/SpaceGrotesk-Bold.ttf";

component ModernCircularIndicator inherits Rectangle {
    in property <bool> active;
    in property <color> active_color;
    in property <color> glow_color;
    
    width: 15px;
    height: 15px;
    border-radius: self.width / 2;
    background: root.active ? root.active_color : rgba(120, 120, 120, 0.15);
    
    animate background { duration: 150ms; easing: ease-in-out; }

    // Outer aura glow
    Rectangle {
        width: 250%;
        height: 250%;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        border-radius: self.width / 2;
        background: root.active ? root.glow_color : transparent;
        opacity: root.active ? 0.22 : 0.0;
        
        animate background { duration: 150ms; }
        animate opacity { duration: 150ms; }
    }
}

export component AppWindow inherits Window {
    title: "Car App";
    preferred-width: 800px;
    preferred-height: 480px;
    background: #0A0A0A; // Instrument Black

    in property <image> map_bg;
    in property <angle> map_rotation: 0deg;
    in property <float> map_rendered_world_x: 0.0;
    in property <float> map_rendered_world_y: 0.0;
    in property <float> current_world_x: 33756.0;
    in property <float> current_world_y: 21962.0;

    property <float> map_scale: Math.max(root.display_size / 800px, root.display_size / 480px);
    property <length> map_pixels_per_unit: 512px * root.map_scale * 0.25;
    property <length> map_shift_x: (root.map_rendered_world_x - root.current_world_x) * root.map_pixels_per_unit;
    property <length> map_shift_y: (root.map_rendered_world_y - root.current_world_y) * root.map_pixels_per_unit;

    in-out property <bool> is_dark_mode: true;
    in-out property <int> current_speed: 75;
    
    // Dashboard properties
    in property <bool> turn_signal_on: false;
    in property <bool> charge_light_on: false;
    in property <bool> oil_light_on: false;
    in property <bool> high_beam_on: false;
    in property <bool> ignition_light_on: false;
    in property <float> fuel_level: 0.75;
    in property <[string]> odometer: ["0", "0", "0", "0", "3", "0"];
    
    // Spotify properties
    in property <bool> spotify_playing: false;
    in property <string> spotify_track: "";
    in property <string> spotify_artist: "";
    in property <float> spotify_progress: 0.0; // 0.0 to 1.0
    in property <image> spotify_album_art;

    callback map_dragged(length, length);
    callback toggle_theme();

    property <length> display_size: min(root.width, root.height);
    property <float> ui_scale: root.display_size / 960px;
    property <color> theme_foreground: root.is_dark_mode ? #F4F1E1 : #353535;

    // Map Layer - Clipped to circular display
    Rectangle {
        width: root.display_size;
        height: root.display_size;
        x: (root.width - self.width) / 2;
        y: (root.height - self.height) / 2;
        border-radius: self.width / 2;
        clip: true;

        // Inner container for rotation and translation
        Rectangle {
            // Make the map image larger than the display so corners don't clip when rotated
            width: root.display_size * 1.5;
            height: root.display_size * 1.5;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            
            // Map renderer previously rotated by -rotation_degrees, so we match it here
            transform-rotation: -root.map_rotation;

            Image {
                width: 100%;
                height: 100%;
                source: root.map_bg;
                image-fit: fill;
                // Shift the map image smoothly
                x: root.map_shift_x;
                y: root.map_shift_y;
            }
        }

        // Outer Ring (70% - 100% radius)
        Rectangle {
            width: 100%;
            height: 100%;
            border-radius: self.width / 2;
            border-width: self.width * 0.15;
            border-color: root.is_dark_mode ? rgba(10, 10, 10, 0.705) : rgba(255, 255, 255, 0.47);
        }

        // Inner Ring (65% - 70% radius)
        Rectangle {
            property <color> gradient_start: root.is_dark_mode ? rgba(10, 10, 10, 0.627) : rgba(255, 255, 255, 0.55);
            property <color> gradient_end: root.is_dark_mode ? rgba(10, 10, 10, 0.157) : rgba(255, 255, 255, 0.08);

            width: parent.width * 0.70;
            height: parent.height * 0.70;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            border-radius: self.width / 2;
            border-width: parent.width * 0.025;
            border-color: @linear-gradient(180deg, self.gradient_start 0%, self.gradient_end 100%);
        }

        // Car Marker Glow
        Rectangle {
            property <float> scale-factor: Math.max(root.width / 800px, root.height / 480px);
            width: 40px * self.scale-factor;
            height: 40px * self.scale-factor;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            border-radius: self.width / 2;
            background: rgba(255, 140, 0, 0.235);
        }

        // Car Marker Inner
        Rectangle {
            property <float> scale-factor: Math.max(root.width / 800px, root.height / 480px);
            width: 20px * self.scale-factor;
            height: 20px * self.scale-factor;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            border-radius: self.width / 2;
            background: rgb(255, 179, 102);
        }

        // Car Arrow
        Path {
            property <float> scale-factor: Math.max(root.width / 800px, root.height / 480px);
            width: 10px * self.scale-factor;
            height: 10px * self.scale-factor;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            commands: "M 1.9 30 L 0 28.4 L 15 0 L 30 28.4 L 28.1 30 L 15 25.3 Z";
            fill: #313126;
            viewbox-width: 30;
            viewbox-height: 30;
        }

        // Integrated Spotify Display
        if root.spotify_playing: Rectangle {
            width: 280px * root.ui_scale;
            height: 70px * root.ui_scale;
            x: (parent.width - self.width) / 2;
            y: parent.height * 0.72;
            border-radius: 12px * root.ui_scale;
            background: root.is_dark_mode ? rgba(15, 15, 15, 0.8) : rgba(255, 255, 255, 0.8);
            border-width: 1px;
            border-color: root.is_dark_mode ? rgba(255, 255, 255, 0.15) : rgba(0, 0, 0, 0.1);

            // Subtle Spotify Logo
            Path {
                width: 14px * root.ui_scale;
                height: 14px * root.ui_scale;
                x: parent.width - self.width - 8px * root.ui_scale;
                y: 8px * root.ui_scale;
                fill: #1DB954;
                opacity: 0.6;
                viewbox-width: 100;
                viewbox-height: 100;
                commands: "M 50 0 C 22.4 0 0 22.4 0 50 C 0 77.6 22.4 100 50 100 C 77.6 100 100 77.6 100 50 C 100 22.4 77.6 0 50 0 Z M 73.1 72.1 C 72.2 73.5 70.3 74 68.9 73.1 C 57.1 65.9 42.2 64.3 24.8 68.3 C 23.2 68.7 21.6 67.7 21.2 66.1 C 20.8 64.5 21.8 62.9 23.4 62.5 C 42.5 58.1 58.9 60 72.1 68.1 C 73.5 69 74 70.8 73.1 72.1 Z M 79.4 58.6 C 78.2 60.5 75.7 61.1 73.8 59.9 C 60.3 51.6 39.8 49.2 24 54 C 21.8 54.7 19.5 53.5 18.8 51.3 C 18.1 49.1 19.3 46.8 21.5 46.1 C 39.5 40.7 62.1 43.4 77.9 53.1 C 79.8 54.2 80.5 56.7 79.4 58.6 Z M 80 44.5 C 64 35 37.4 34.1 22 38.8 C 19.5 39.6 16.9 38.2 16.1 35.7 C 15.3 33.2 16.7 30.6 19.2 29.8 C 37 24.4 66.4 25.4 84.8 36.3 C 87.1 37.7 87.8 40.7 86.4 43 C 85 45.3 82 46.1 79.7 44.7 L 80 44.5 Z";
            }

            HorizontalLayout {
                padding: 8px * root.ui_scale;
                spacing: 10px * root.ui_scale;
                alignment: start;

                // Album Art thumbnail
                Rectangle {
                    width: 54px * root.ui_scale;
                    height: 54px * root.ui_scale;
                    border-radius: 4px * root.ui_scale;
                    clip: true;
                    background: #121212;
                    
                    Image {
                        source: root.spotify_album_art;
                        width: 100%;
                        height: 100%;
                        image-fit: cover;
                    }
                }

                VerticalLayout {
                    spacing: 4px * root.ui_scale;
                    alignment: center;

                    VerticalLayout {
                        spacing: 0;
                        Text {
                            text: root.spotify_track;
                            font-size: 14px * root.ui_scale;
                            font-family: "Space Grotesk";
                            font-weight: 700;
                            color: root.theme_foreground;
                            overflow: elide;
                        }
                        Text {
                            text: root.spotify_artist;
                            font-size: 11px * root.ui_scale;
                            font-family: "Space Grotesk";
                            font-weight: 500;
                            color: root.is_dark_mode ? rgba(255, 255, 255, 0.5) : rgba(0, 0, 0, 0.5);
                            overflow: elide;
                        }
                    }

                    Rectangle {
                        height: 3px * root.ui_scale;
                        width: 180px * root.ui_scale;
                        background: root.is_dark_mode ? rgba(255, 255, 255, 0.15) : rgba(0, 0, 0, 0.15);
                        border-radius: 1.5px * root.ui_scale;

                        Rectangle {
                            x: 0;
                            y: 0;
                            height: parent.height;
                            width: parent.width * root.spotify_progress;
                            background: #1DB954;
                            border-radius: parent.border-radius;
                        }
                    }
                }
            }
        }
    }

    // --- STATIC CACHED DASHBOARD ELEMENTS ---
    // These paths and texts are very expensive to software-rasterize on every frame.
    // By wrapping them in a Rectangle with cache-rendering-hint, Slint draws them
    // once into a texture and re-uses the texture, saving ~50% CPU!
    Rectangle {
        width: 100%;
        height: 100%;
        cache-rendering-hint: true;

        // Speed Arch
    for i in 71 : Path {
        property <int> speed: 10 + i * 2;
        property <angle> angle: -120deg + (i / 70.0) * 240deg;
        
        property <length> r_outer: root.display_size / 2 * 0.96;
        property <length> r_inner: r_outer - 12px * root.ui_scale;
        
        property <bool> is_div_20: Math.mod(speed, 20) == 0;
        property <bool> is_div_10: Math.mod(speed, 10) == 0;
        property <length> sw: is_div_20 ? 16px * root.ui_scale : (is_div_10 ? 6px * root.ui_scale : 1px);
        property <length> hw: sw / 2;
        
        fill: root.theme_foreground;
        
        width: root.width;
        height: root.height;
        viewbox-width: root.width / 1px;
        viewbox-height: root.height / 1px;
        
        MoveTo {
            x: (root.width / 2 + sin(angle) * r_inner - cos(angle) * hw) / 1px;
            y: (root.height / 2 - cos(angle) * r_inner - sin(angle) * hw) / 1px;
        }
        LineTo {
            x: (root.width / 2 + sin(angle) * r_inner + cos(angle) * hw) / 1px;
            y: (root.height / 2 - cos(angle) * r_inner + sin(angle) * hw) / 1px;
        }
        LineTo {
            x: (root.width / 2 + sin(angle) * r_outer + cos(angle) * hw) / 1px;
            y: (root.height / 2 - cos(angle) * r_outer + sin(angle) * hw) / 1px;
        }
        LineTo {
            x: (root.width / 2 + sin(angle) * r_outer - cos(angle) * hw) / 1px;
            y: (root.height / 2 - cos(angle) * r_outer - sin(angle) * hw) / 1px;
        }
        Close {}
    }
    



    // Speed Numbers
    for i in 7 : Text {
        property <int> speed: 20 + i * 20;
        property <int> dash_idx: (speed - 10) / 2;
        property <angle> angle: -120deg + (dash_idx / 70.0) * 240deg;
        property <length> r_text: root.display_size / 2 * 0.87;
        
        text: speed;
        font-size: 60px * root.ui_scale;
        font-weight: 300;
        font-family: "Space Grotesk";
        color: root.theme_foreground;
        
        x: root.width / 2 + sin(angle) * r_text - self.width / 2;
        y: root.height / 2 - cos(angle) * r_text - self.height / 2;
        
        // Bottom faces center (angle), except first and last face outwards (+180deg)
        transform-rotation: (i == 0 || i == 6) ? angle + 180deg : angle;
    }

    // Odometer (Kilometer Counter) positioned just above the fuel gauge in the outer ring
    Rectangle {
        property <angle> a: 180deg;
        property <length> r_dist: root.display_size / 2 * 0.67;
        width: 130px * root.ui_scale;
        height: 32px * root.ui_scale;
        x: root.width / 2 + sin(self.a) * self.r_dist - self.width / 2;
        y: root.height / 2 - cos(self.a) * self.r_dist - self.height / 2;
        background: #111;
        border-color: #333;
        border-width: 1px * root.ui_scale;
        
        HorizontalLayout {
            spacing: 2px * root.ui_scale;
            padding: 2px * root.ui_scale;
            for digit[idx] in root.odometer : Rectangle {
                background: #000;
                width: 18px * root.ui_scale;
                Text {
                    text: digit;
                    color: idx == 5 ? #FFB300 : #FFF;
                    font-family: "Space Grotesk";
                    font-weight: 500;
                    font-size: 20px * root.ui_scale;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }
    }

    // Center Fuel Label (Slightly smaller, positioned above the fuel ticks)
    Text {
        property <angle> a: 180deg;
        property <length> r_dist: root.display_size / 2 * 0.77;
        text: "FUEL";
        font-size: 11px * root.ui_scale;
        font-family: "Space Grotesk";
        font-weight: 500;
        letter-spacing: 1.5px * root.ui_scale;
        color: root.theme_foreground;
        x: root.width / 2 + sin(self.a) * self.r_dist - self.width / 2;
        y: root.height / 2 - cos(self.a) * self.r_dist - self.height / 2;
    }

    // Fuel Gauge Texts (Original layout, fully at the bottom)
    for t[i] in ["E", "1/2", "F"] : Text {
        property <angle> a: 180deg + 20deg - i * 20deg;
        property <length> r_t: root.display_size / 2 * 0.86;
        
        text: t;
        font-size: 16px * root.ui_scale;
        font-family: "Space Grotesk";
        font-weight: 500;
        color: root.theme_foreground;
        x: root.width / 2 + sin(a) * r_t - self.width / 2;
        y: root.height / 2 - cos(a) * r_t - self.height / 2;
    }

    // Fuel Gauge Ticks (Original layout, fully at the bottom)
    for i in 5 : Path {
        property <angle> a: 180deg + 20deg - i * 10deg;
        property <length> r_in: root.display_size / 2 * 0.94;
        property <length> r_out: root.display_size / 2 * 0.97;
        property <length> hw: 1.5px * root.ui_scale;
        
        fill: root.theme_foreground;
        
        width: root.width;
        height: root.height;
        viewbox-width: root.width / 1px;
        viewbox-height: root.height / 1px;
        
        MoveTo { x: (root.width / 2 + sin(a) * r_in - cos(a) * hw) / 1px; y: (root.height / 2 - cos(a) * r_in - sin(a) * hw) / 1px; }
        LineTo { x: (root.width / 2 + sin(a) * r_in + cos(a) * hw) / 1px; y: (root.height / 2 - cos(a) * r_in + sin(a) * hw) / 1px; }
        LineTo { x: (root.width / 2 + sin(a) * r_out + cos(a) * hw) / 1px; y: (root.height / 2 - cos(a) * r_out + sin(a) * hw) / 1px; }
        LineTo { x: (root.width / 2 + sin(a) * r_out - cos(a) * hw) / 1px; y: (root.height / 2 - cos(a) * r_out - sin(a) * hw) / 1px; }
        Close {}
    }
    } // End of static cached elements

    // Fuel Gauge Needle (Original layout, fully at the bottom)
    Path {
        property <angle> a: 180deg + 20deg - root.fuel_level * 40deg;
        property <length> r_in: root.display_size / 2 * 0.89;
        property <length> r_out: root.display_size / 2 * 0.98;
        property <length> hw: 3.5px * root.ui_scale;
        
        fill: #FF8C00;
        
        width: root.width;
        height: root.height;
        viewbox-width: root.width / 1px;
        viewbox-height: root.height / 1px;
        
        MoveTo { x: (root.width / 2 + sin(a) * r_in - cos(a) * hw) / 1px; y: (root.height / 2 - cos(a) * r_in - sin(a) * hw) / 1px; }
        LineTo { x: (root.width / 2 + sin(a) * r_in + cos(a) * hw) / 1px; y: (root.height / 2 - cos(a) * r_in + sin(a) * hw) / 1px; }
        LineTo { x: (root.width / 2 + sin(a) * r_out + cos(a) * hw * 0.4) / 1px; y: (root.height / 2 - cos(a) * r_out + sin(a) * hw * 0.4) / 1px; }
        LineTo { x: (root.width / 2 + sin(a) * r_out - cos(a) * hw * 0.4) / 1px; y: (root.height / 2 - cos(a) * r_out - sin(a) * hw * 0.4) / 1px; }
        Close {}
    }

    // Modern Radial Dashboard Indicator Lights (Smiths Dial Positions)
    
    // Top Green (Turn Signal)
    ModernCircularIndicator {
        property <angle> a: 0deg;
        property <length> r_dist: root.display_size / 2 * 0.77;
        x: root.width / 2 + sin(a) * r_dist - self.width / 2;
        y: root.height / 2 - cos(a) * r_dist - self.height / 2;
        width: 16px * root.ui_scale;
        height: 16px * root.ui_scale;
        
        active: root.turn_signal_on;
        active_color: #00FF66; // Vibrant neon green
        glow_color: rgba(0, 255, 102, 0.22);
    }

    // Left Red (Charge/Ignition)
    ModernCircularIndicator {
        property <angle> a: -102.85deg;
        property <length> r_dist: root.display_size / 2 * 0.77;
        x: root.width / 2 + sin(a) * r_dist - self.width / 2;
        y: root.height / 2 - cos(a) * r_dist - self.height / 2;
        width: 15px * root.ui_scale;
        height: 15px * root.ui_scale;
        
        active: root.charge_light_on;
        active_color: #FF2A2A; // Vibrant neon red
        glow_color: rgba(255, 42, 42, 0.22);
    }

    // Right Red (Oil/Warning)
    ModernCircularIndicator {
        property <angle> a: 102.85deg;
        property <length> r_dist: root.display_size / 2 * 0.77;
        x: root.width / 2 + sin(a) * r_dist - self.width / 2;
        y: root.height / 2 - cos(a) * r_dist - self.height / 2;
        width: 15px * root.ui_scale;
        height: 15px * root.ui_scale;
        
        active: root.oil_light_on;
        active_color: #FF2A2A; // Vibrant neon red
        glow_color: rgba(255, 42, 42, 0.22);
    }

    // Bottom Left (H/B)
    ModernCircularIndicator {
        property <angle> a: -140deg;
        property <length> r_dist: root.display_size / 2 * 0.82;
        x: root.width / 2 + sin(a) * r_dist - self.width / 2;
        y: root.height / 2 - cos(a) * r_dist - self.height / 2;
        width: 14px * root.ui_scale;
        height: 14px * root.ui_scale;
        
        active: root.high_beam_on;
        active_color: #0088FF; // Vibrant neon blue
        glow_color: rgba(0, 136, 255, 0.22);
    }
    Text {
        property <angle> a: -140deg;
        property <length> r_dist: root.display_size / 2 * 0.88;
        text: "H/B";
        font-size: 10px * root.ui_scale;
        font-family: "Space Grotesk";
        font-weight: 700;
        color: root.theme_foreground;
        x: root.width / 2 + sin(a) * r_dist - self.width / 2;
        y: root.height / 2 - cos(a) * r_dist - self.height / 2;
        opacity: root.high_beam_on ? 1.0 : 0.45;
        
        animate opacity { duration: 150ms; }
    }

    // Bottom Right (IGN)
    ModernCircularIndicator {
        property <angle> a: 140deg;
        property <length> r_dist: root.display_size / 2 * 0.82;
        x: root.width / 2 + sin(a) * r_dist - self.width / 2;
        y: root.height / 2 - cos(a) * r_dist - self.height / 2;
        width: 14px * root.ui_scale;
        height: 14px * root.ui_scale;
        
        active: root.ignition_light_on;
        active_color: #FF9900; // Vibrant neon amber/orange
        glow_color: rgba(255, 153, 0, 0.22);
    }
    Text {
        property <angle> a: 140deg;
        property <length> r_dist: root.display_size / 2 * 0.88;
        text: "IGN";
        font-size: 10px * root.ui_scale;
        font-family: "Space Grotesk";
        font-weight: 700;
        color: root.theme_foreground;
        x: root.width / 2 + sin(a) * r_dist - self.width / 2;
        y: root.height / 2 - cos(a) * r_dist - self.height / 2;
        opacity: root.ignition_light_on ? 1.0 : 0.45;
        
        animate opacity { duration: 150ms; }
    }

    // Needle
    Path {
        property <angle> needle_angle: -120deg + (Math.max(10, Math.min(150, root.current_speed)) - 10) / 140.0 * 240deg;
        property <length> r_in: root.display_size / 2 * 0.70;
        property <length> r_out: root.display_size / 2 * 0.96 - 14px * root.ui_scale; 
        
        fill: #FF8C00; // NFS Glow Orange
        
        width: root.width;
        height: root.height;
        viewbox-width: root.width / 1px;
        viewbox-height: root.height / 1px;
        
        transform-rotation: self.needle_angle;
        
        MoveTo {
            x: (root.width / 2 - 6px * root.ui_scale) / 1px;
            y: (root.height / 2 - r_in) / 1px;
        }
        LineTo {
            x: (root.width / 2 - 2px * root.ui_scale) / 1px;
            y: (root.height / 2 - r_out) / 1px;
        }
        LineTo {
            x: (root.width / 2) / 1px;
            y: (root.height / 2 - r_out - 8px * root.ui_scale) / 1px;
        }
        LineTo {
            x: (root.width / 2 + 2px * root.ui_scale) / 1px;
            y: (root.height / 2 - r_out) / 1px;
        }
        LineTo {
            x: (root.width / 2 + 6px * root.ui_scale) / 1px;
            y: (root.height / 2 - r_in) / 1px;
        }
        Close {}
    }

    TouchArea {
        property <length> start_x;
        property <length> start_y;
        
        pointer-event(event) => {
            if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                self.start_x = self.mouse-x;
                self.start_y = self.mouse-y;
            }
        }
        
        moved => {
            let dx = self.mouse-x - self.start_x;
            let dy = self.mouse-y - self.start_y;
            self.start_x = self.mouse-x;
            self.start_y = self.mouse-y;
            root.map_dragged(dx, dy);
        }
    }

    // Debug Theme Switcher (Visible only in dev)
    TouchArea {
        x: 20px;
        y: 20px;
        width: 100px;
        height: 40px;
        clicked => { root.toggle_theme() }
        
        Rectangle {
            background: root.is_dark_mode ? rgba(255, 255, 255, 0.1) : rgba(0, 0, 0, 0.1);
            border-color: root.is_dark_mode ? rgba(255, 255, 255, 0.3) : rgba(0, 0, 0, 0.3);
            border-width: 1px;
            border-radius: 4px;
            
            Text {
                text: root.is_dark_mode ? "DARK" : "LIGHT";
                vertical-alignment: center;
                horizontal-alignment: center;
                color: root.is_dark_mode ? #FFFFFF : #000000;
            }
        }
    }
}
